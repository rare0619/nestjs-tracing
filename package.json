{
    "name": "@rare0619/nestjs-tracing",
    "version": "1.2.0",
    "description": "NestJS 全链路追踪插件（OpenTelemetry + Elastic APM）— 自动插桩、日志关联、跨服务传播、Monorepo 零配置",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./tracer": {
            "types": "./dist/tracer.d.ts",
            "default": "./dist/tracer.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run build",
        "test": "jest --forceExit --detectOpenHandles",
        "test:cov": "jest --coverage --forceExit --detectOpenHandles"
    },
    "keywords": [
        "nestjs",
        "opentelemetry",
        "tracing",
        "elastic-apm",
        "distributed-tracing",
        "observability",
        "monorepo"
    ],
    "author": "rare0619",
    "license": "Apache-2.0",
    "peerDependencies": {
        "@opentelemetry/api": "^1.9.0",
        "winston": "^3.0.0"
    },
    "peerDependenciesMeta": {
        "winston": {
            "optional": true
        }
    },
    "dependencies": {
        "@opentelemetry/core": "^1.30.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.57.2",
        "@opentelemetry/instrumentation-express": "^0.46.0",
        "@opentelemetry/instrumentation-http": "^0.57.0",
        "@opentelemetry/instrumentation-ioredis": "^0.61.0",
        "@opentelemetry/instrumentation-pg": "^0.65.0",
        "@opentelemetry/resources": "^1.30.0",
        "@opentelemetry/sdk-node": "^0.57.0",
        "@opentelemetry/semantic-conventions": "^1.30.0"
    },
    "devDependencies": {
        "@nestjs/common": "^10.0.0",
        "@opentelemetry/api": "^1.9.0",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.11.0",
        "express": "^4.18.0",
        "jest": "^29.7.0",
        "reflect-metadata": "^0.2.0",
        "ts-jest": "^29.2.0",
        "typescript": "^5.3.0",
        "winston": "^3.17.0"
    },
    "files": [
        "dist",
        "README.md"
    ]
}